---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolCard from '../../components/ToolCard.astro';
import FilterBar from '../../components/FilterBar.astro';
import { STAGES } from '../../data/taxonomy';

export async function getStaticPaths() {
  return STAGES.map((s) => ({
    params: { slug: s.slug },
    props: { stage: s },
  }));
}

const { stage } = Astro.props;
const allTools = await getCollection('tools');
const tools = allTools
  .filter((t) => t.data.stages.includes(stage.slug))
  .sort((a, b) => a.data.name.localeCompare(b.data.name));
---
<BaseLayout
  title={`Best tools for ${stage.label} founders`}
  description={`${stage.desc} ${tools.length} curated tools picked specifically for this stage.`}
>
  <section class="page-hero container">
    <div class="page-hero__eyebrow">Founder stage</div>
    <h1>{stage.label}</h1>
    <p class="page-hero__lede">{stage.desc}</p>
  </section>

  <div class="container">
    <FilterBar hideStageFilter={true} />

    <div class="tools-grid">
      {tools.length === 0 ? (
        <div class="empty-state">
          <p>Nothing in our directory tagged for this stage yet.</p>
        </div>
      ) : (
        tools.map((tool) => <ToolCard tool={tool} />)
      )}
    </div>

    <div class="empty-state" id="empty-state" style="display: none;">
      <p>No tools match these filters yet.</p>
    </div>
  </div>
</BaseLayout>
