---
import BaseLayout from '../layouts/BaseLayout.astro';

// CONFIGURE: Paste the public URL of your Tally tool-submission form below.
// This is the intake form that used to be set as the Stripe success URL.
// It is NOT the newsletter form (2ElR09) used on the homepage.
// Example: https://tally.so/r/XXXXXX
const TALLY_SUBMIT_FORM_URL = 'REPLACE_WITH_TALLY_SUBMIT_FORM_URL';

const base = import.meta.env.BASE_URL;
---
<BaseLayout
  title="Submit your tool · We Are Founders Directory"
  description="Submit your SaaS, agency tool, or founder product for free editorial review and inclusion in the We Are Founders tools directory. Every entry is hand-reviewed."
>
  <section class="container submit-page">
    <div class="submit-page__eyebrow">Editorial Submission</div>
    <h1 class="submit-page__heading">
      Submit your tool for <em>editorial review.</em>
    </h1>
    <p class="submit-page__lead">
      We Are Founders Tools is a curated directory. Every entry is hand-reviewed for quality, relevance, and editorial fit. Submitting is free. We just ask that your product is live and genuinely useful to founders before you send it our way.
    </p>

    <div class="submit-card">
      <h2 class="submit-card__heading">What you get</h2>
      <p>
        Every accepted tool gets a full directory entry written in our house style. We verify your pricing and feature claims, write the entry, and publish it alongside the rest of the directory with the same depth as our editorially selected tools.
      </p>

      <p>
        Affiliate links are welcome. If you're submitting your own tool and run an affiliate program, we'll happily use your tracked link as the primary CTA on the entry. Tools without an affiliate program are listed with a direct link to your site.
      </p>

      <h2 class="submit-card__heading">What we look for</h2>
      <p>
        We accept tools that genuinely help founders, indie hackers, or early-stage operators. Most categories in our taxonomy are open: AI agents, automation, developer tools, finance ops, growth marketing, sales CRM, productivity, design, hiring, and more.
      </p>

      <p>
        We reject tools that are vapourware or pre-launch with no real product, derivative wrappers around obvious AI APIs with no meaningful value-add, anything that breaks our content policies, and tools where the user experience is meaningfully poor. Please make sure your product is live and ready before you submit.
      </p>

      <h2 class="submit-card__heading">How it works</h2>
      <ol class="submit-card__steps">
        <li>Fill in the short submission form with your tool's details.</li>
        <li>We review within 5 business days for quality, relevance, and editorial fit.</li>
        <li>We email you with the published URL or, in the rare case of rejection, a short explanation of why.</li>
        <li>Your listing stays live indefinitely. We may refresh pricing or details over time as part of our regular directory maintenance.</li>
      </ol>

      <a href={TALLY_SUBMIT_FORM_URL} class="submit-card__cta" rel="noopener">
        Submit your tool →
      </a>

      <p class="submit-card__small">
        Takes a couple of minutes. We'll be in touch within 5 business days.
      </p>
    </div>

    <div class="submit-faq">
      <h2 class="submit-card__heading">Common questions</h2>

      <h3>Can I submit a tool I don't own?</h3>
      <p>
        Yes. Agencies, freelancers, and content marketers occasionally submit tools they're not affiliated with. We treat every submission the same way.
      </p>

      <h3>Is this a sponsored listing?</h3>
      <p>
        No. Submission is free and every entry meets the same editorial standard as our hand-selected tools. Listings aren't marked as sponsored because they aren't. If we wouldn't be willing to write the entry, we won't publish it.
      </p>

      <h3>What if my tool changes or I want to update the listing?</h3>
      <p>
        Email us with the changes. Minor updates like a new pricing tier or an added feature are no problem. For a substantial repositioning, get in touch and we'll take a look.
      </p>

      <h3>Do you offer a featured slot?</h3>
      <p>
        Featured placement is reserved for tools we consider exceptional or that have strong founder relevance. It's not for sale. If your submission earns a featured slot during review, that's at our discretion.
      </p>

      <h3>What if you reject my submission?</h3>
      <p>
        We'll email you a short explanation. Our rejection rate is low because most founder-focused tools clear the bar, but we reserve editorial judgement. You're welcome to resubmit once you've addressed whatever held it back.
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .submit-page {
    padding-top: 3rem;
    padding-bottom: 5rem;
    max-width: 760px;
  }
  .submit-page__eyebrow {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--waf-accent);
    margin-bottom: 1rem;
  }
  .submit-page__heading {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 600;
    letter-spacing: -0.03em;
    line-height: 1.05;
    margin: 0 0 1.5rem;
  }
  .submit-page__heading em {
    font-style: italic;
    color: var(--waf-accent);
    font-weight: 500;
  }
  .submit-page__lead {
    font-size: 1.125rem;
    color: var(--text-muted);
    line-height: 1.55;
    margin-bottom: 2.5rem;
  }
  .submit-card {
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 2.5rem;
    background: var(--bg-subtle);
    margin-bottom: 3rem;
  }
  .submit-card__heading {
    font-family: var(--font-display);
    font-size: 1.375rem;
    font-weight: 600;
    margin: 2rem 0 0.875rem;
    letter-spacing: -0.02em;
  }
  .submit-card__heading:first-of-type { margin-top: 0; }
  .submit-card p {
    line-height: 1.6;
    color: var(--text);
    margin: 0 0 1rem;
  }
  .submit-card__steps {
    padding-left: 1.25rem;
    margin: 0 0 2rem;
  }
  .submit-card__steps li {
    line-height: 1.6;
    margin-bottom: 0.625rem;
  }
  .submit-card__cta {
    display: block;
    text-align: center;
    background: var(--waf-accent);
    color: white !important;
    padding: 1.125rem 1.5rem;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 600;
    font-size: 1.0625rem;
    margin: 2rem 0 1rem;
    transition: opacity 120ms ease;
  }
  .submit-card__cta:hover { opacity: 0.92; }
  .submit-card__small {
    text-align: center;
    font-size: 0.8125rem;
    color: var(--text-muted);
    margin: 0 !important;
  }
  .submit-faq h3 {
    font-family: var(--font-display);
    font-size: 1.0625rem;
    font-weight: 600;
    margin: 1.5rem 0 0.5rem;
    letter-spacing: -0.01em;
  }
  .submit-faq p {
    color: var(--text-muted);
    line-height: 1.6;
    margin: 0 0 1rem;
  }
</style>
