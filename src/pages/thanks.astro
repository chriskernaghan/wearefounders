---
import BaseLayout from '../layouts/BaseLayout.astro';
const PROMOTE = '/promote/';
const TALLY_PACKAGE = 'https://tally.so/r/PdvzgQ'; // same intake; package interest captured there
---
<BaseLayout
  title="Submission received — We Are Founders Directory"
  description="Your tool submission has been received. Here's what happens next, and how to get more reach."
>
  <div class="container thanks">
    <section class="thanks__hero">
      <span class="thanks__check" aria-hidden="true">✓</span>
      <h1>You're in</h1>
      <p class="thanks__lede">
        Thanks for submitting your tool. We review every listing by hand to keep the
        directory useful, so yours will appear once it's been checked. No further
        action needed from you.
      </p>
    </section>

    <section class="thanks__upsell">
      <div class="thanks__upsell-head">
        <span class="thanks__eyebrow">Want to be seen first?</span>
        <h2>Boost your reach</h2>
        <p>
          Your listing is free and stays free. If you want more eyes on it, these
          packages put you at the top of the directory, in a full story on We Are
          Founders, and in front of our newsletter readers.
        </p>
      </div>

      <div class="thanks__tiers">
        <div class="thanks__tier">
          <div class="thanks__tier-name">Spotlight</div>
          <div class="thanks__tier-price">$49</div>
          <div class="thanks__tier-desc">Featured at the top for 30 days.</div>
        </div>
        <div class="thanks__tier thanks__tier--featured">
          <span class="thanks__tier-badge">Most popular</span>
          <div class="thanks__tier-name">Spotlight + Story</div>
          <div class="thanks__tier-price">$199</div>
          <div class="thanks__tier-desc">Featured, plus a full story and a dofollow link.</div>
        </div>
        <div class="thanks__tier">
          <div class="thanks__tier-name">+ Brief</div>
          <div class="thanks__tier-price">$399</div>
          <div class="thanks__tier-desc">All of the above, plus a Friday Brief slot.</div>
        </div>
      </div>

      <div class="thanks__cta-row">
        <a class="btn btn--primary" href={PROMOTE}>See full packages →</a>
        <a class="btn btn--ghost" href="/">Back to the directory</a>
      </div>
    </section>
  </div>

  <style>
    .thanks { padding-block: 3rem 5rem; max-width: 760px; }

    .thanks__hero { text-align: center; margin-bottom: 3.5rem; }
    .thanks__check {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 56px;
      height: 56px;
      border-radius: 50%;
      background: var(--waf-accent);
      color: #fff;
      font-size: 1.75rem;
      font-weight: 700;
      margin-bottom: 1.5rem;
    }
    .thanks__hero h1 { margin: 0 0 1rem; }
    .thanks__lede {
      font-size: 1.0625rem;
      color: var(--text-muted);
      line-height: 1.6;
      max-width: 52ch;
      margin: 0 auto;
    }

    .thanks__upsell {
      border: 1px solid var(--border);
      border-radius: var(--radius-lg);
      padding: 2.5rem;
      background: var(--bg-elevated);
    }
    .thanks__upsell-head { text-align: center; margin-bottom: 2rem; }
    .thanks__eyebrow {
      font-family: var(--font-mono);
      font-size: 0.75rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--waf-accent);
    }
    .thanks__upsell-head h2 { margin: 0.5rem 0 0.75rem; font-size: 1.75rem; }
    .thanks__upsell-head p {
      font-size: 0.9375rem;
      color: var(--text-muted);
      line-height: 1.6;
      max-width: 56ch;
      margin: 0 auto;
    }

    .thanks__tiers {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1rem;
      margin-bottom: 2rem;
    }
    @media (max-width: 640px) {
      .thanks__tiers { grid-template-columns: 1fr; }
    }
    .thanks__tier {
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 1.25rem;
      text-align: center;
      position: relative;
      background: var(--bg);
    }
    .thanks__tier--featured {
      border-color: var(--waf-accent);
      border-width: 2px;
      background: var(--waf-accent-soft);
    }
    .thanks__tier-badge {
      position: absolute;
      top: -0.6rem;
      left: 50%;
      transform: translateX(-50%);
      background: var(--waf-accent);
      color: #fff;
      font-family: var(--font-mono);
      font-size: 0.625rem;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      padding: 0.25rem 0.6rem;
      border-radius: 999px;
      white-space: nowrap;
    }
    .thanks__tier-name {
      font-family: var(--font-display);
      font-weight: 600;
      font-size: 0.9375rem;
      margin-bottom: 0.4rem;
      color: var(--text);
    }
    .thanks__tier-price {
      font-family: var(--font-display);
      font-weight: 600;
      font-size: 1.75rem;
      line-height: 1;
      margin-bottom: 0.5rem;
      color: var(--text);
    }
    .thanks__tier-desc {
      font-size: 0.8125rem;
      color: var(--text-muted);
      line-height: 1.4;
    }

    .thanks__cta-row {
      display: flex;
      gap: 0.75rem;
      justify-content: center;
      flex-wrap: wrap;
    }
  </style>
</BaseLayout>
