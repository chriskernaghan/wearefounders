---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ToolCard from '../components/ToolCard.astro';
import FilterBar from '../components/FilterBar.astro';
import { STAGES, CATEGORIES } from '../data/taxonomy';
import NewsletterSignup from '../components/NewsletterSignup.astro';
import PromoMarquee from '../components/PromoMarquee.astro';

const tools = await getCollection('tools');
const sorted = tools.sort((a, b) => {
  if (a.data.featured && !b.data.featured) return -1;
  if (!a.data.featured && b.data.featured) return 1;
  return a.data.name.localeCompare(b.data.name);
});

// Static per-category counts for the sidebar
const categoryCounts: Record<string, number> = {};
sorted.forEach((tool) => {
  (tool.data.categories || []).forEach((slug: string) => {
    categoryCounts[slug] = (categoryCounts[slug] || 0) + 1;
  });
});

const base = import.meta.env.BASE_URL;
---
<BaseLayout
  title="The We Are Founders Tools Directory"
  description="A curated, editorial directory of the tools that actually move the needle for founders. Filtered by category, founder stage, and pricing. Every entry is hand-reviewed."
  bodyClass="is-home"
>
  <section class="hero" aria-labelledby="hero-heading">
    <div class="hero__bg-word" aria-hidden="true">TOOLS</div>
    <div class="container hero__inner">
      <div class="hero__eyebrow">The Directory</div>
      <h1 class="hero__heading" id="hero-heading">
        Tools founders <em>actually use.</em>
      </h1>
      <div class="hero__signup">
        <NewsletterSignup />
      </div>
    </div>
    <div class="hero__strip">
      <div class="container hero__strip-inner">
        <span>{tools.length} tools</span>
        <span>Operator-reviewed</span>
        <span>Free to submit</span>
        <span>Updated weekly</span>
      </div>
    </div>
  </section>

<PromoMarquee />

  <div class="container">
    <div class="directory-layout">
      <aside class="filter-sidebar" aria-label="Filter by category">
        <h2 class="filter-sidebar__title">Categories</h2>
        <ul class="filter-sidebar__list" data-filter-group="category" role="group">
          <li>
            <button type="button" class="filter-row" data-filter-value="all" aria-pressed="true">
              <span class="filter-row__label">All</span>
              <span class="filter-row__count">{sorted.length}</span>
            </button>
          </li>
          {CATEGORIES.map((c) => (
            <li>
              <button type="button" class="filter-row" data-filter-value={c.slug} aria-pressed="false">
                <span class="filter-row__label">{c.label}</span>
                <span class="filter-row__count">{categoryCounts[c.slug] || 0}</span>
              </button>
            </li>
          ))}
        </ul>
      </aside>

      <main class="directory-main">
        <div class="category-strip directory-main__mobile-filters" id="category-strip-mobile">
          <div class="category-strip__scroll-wrap">
            <div class="category-strip__pills" data-filter-group="category">
              <button type="button" class="pill" data-filter-value="all" aria-pressed="true">All</button>
              {CATEGORIES.map((c) => (
                <button type="button" class="pill" data-filter-value={c.slug} aria-pressed="false">
                  {c.label}
                </button>
              ))}
            </div>
            <div class="category-strip__fade" aria-hidden="true"></div>
          </div>
        </div>

        <FilterBar hideCategoryFilter={true} />

        <div class="tools-grid">
          {sorted.map((tool) => <ToolCard tool={tool} />)}
        </div>

        <div class="empty-state" id="empty-state" style="display: none;">
          <p>No tools match these filters yet. Try widening your selection.</p>
        </div>
      </main>
    </div>

    <div class="section-heading">
      <h2>Tools for where you're at</h2>
    </div>
    <p class="section-lede">
      Stage-specific picks. Whether you're validating, building toward your first
      paying users, or growing past PMF, these are the tools we'd reach for.
    </p>
    <div class="tools-grid">
      {STAGES.map((s) => (
        <a href={`${base}stage/${s.slug}/`} class="tool-card">
          <div class="tool-card__head">
            <div class="tool-card__name">{s.label}</div>
          </div>
          <p class="tool-card__tagline">{s.desc}</p>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>

<script>
  // Homepage-only: header transitions from over-hero (purple/white text) to
  // cream once the user scrolls past the hero block. Uses IntersectionObserver
  // with rootMargin shrunk by the sticky header's height.
  const header = document.querySelector<HTMLElement>('.site-header');
  const hero = document.querySelector<HTMLElement>('.hero');

  if (header && hero) {
    let observer: IntersectionObserver | null = null;

    // Expose the header's measured height as a CSS variable so the hero
    // can pull itself up underneath the transparent header by exactly
    // the right amount.
    const setHeaderHeightVar = () => {
      document.documentElement.style.setProperty(
        '--site-header-h',
        `${header.offsetHeight}px`
      );
    };

    const setup = () => {
      observer?.disconnect();
      setHeaderHeightVar();
      const headerHeight = header.offsetHeight;
      observer = new IntersectionObserver(
        ([entry]) => {
          header.classList.toggle('site-header--past-hero', !entry.isIntersecting);
        },
        {
          rootMargin: `-${headerHeight}px 0px 0px 0px`,
          threshold: 0,
        }
      );
      observer.observe(hero);
    };

    setup();

    let resizeTimer: number;
    window.addEventListener('resize', () => {
      window.clearTimeout(resizeTimer);
      resizeTimer = window.setTimeout(setup, 150);
    }, { passive: true });
  }
</script>
