---
import { CATEGORIES, STAGES } from '../data/taxonomy';

interface Props {
  // When true, hide the category filter row (used on category pages where
  // the category is already determined by the URL).
  hideCategoryFilter?: boolean;
  // When true, hide the stage filter row (used on stage pages).
  hideStageFilter?: boolean;
}

const { hideCategoryFilter = false, hideStageFilter = false } = Astro.props;
---
<div class="filter-bar" id="filter-bar">
  {!hideStageFilter && (
    <div class="filter-bar__row">
      <span class="filter-bar__label">Stage</span>
      <div class="filter-bar__pills" data-filter-group="stage">
        <button type="button" class="pill" data-filter-value="all" aria-pressed="true">All</button>
        {STAGES.map((s) => (
          <button type="button" class="pill" data-filter-value={s.slug} aria-pressed="false">
            {s.label}
          </button>
        ))}
      </div>
    </div>
  )}

  {!hideCategoryFilter && (
    <div class="filter-bar__row">
      <span class="filter-bar__label">Category</span>
      <div class="filter-bar__pills" data-filter-group="category">
        <button type="button" class="pill" data-filter-value="all" aria-pressed="true">All</button>
        {CATEGORIES.map((c) => (
          <button type="button" class="pill" data-filter-value={c.slug} aria-pressed="false">
            {c.label}
          </button>
        ))}
      </div>
    </div>
  )}

  <div class="filter-bar__row">
    <span class="filter-bar__label">Refine</span>
    <div class="filter-bar__pills" data-filter-group="freetier">
      <button type="button" class="pill" data-filter-value="all" aria-pressed="true">All tools</button>
      <button type="button" class="pill" data-filter-value="true" aria-pressed="false">Free tier only</button>
    </div>
    <span class="filter-bar__count" id="filter-count">Loading…</span>
  </div>
</div>

<script>
  // Multi-axis client-side filter. Reads selected values per group,
  // shows tools that match ALL active groups (AND logic across groups,
  // single-select within each group for simplicity).
  type GroupName = 'stage' | 'category' | 'freetier';
  const state: Record<GroupName, string> = {
    stage: 'all',
    category: 'all',
    freetier: 'all',
  };

  function apply() {
    const tools = document.querySelectorAll<HTMLElement>('[data-tool]');
    let visible = 0;

    tools.forEach((el) => {
      const cats = (el.dataset.categories ?? '').split(',');
      const stages = (el.dataset.stages ?? '').split(',');
      const freeTier = el.dataset.freeTier ?? 'false';

      const matchesStage = state.stage === 'all' || stages.includes(state.stage);
      const matchesCategory = state.category === 'all' || cats.includes(state.category);
      const matchesFree = state.freetier === 'all' || freeTier === state.freetier;

      const show = matchesStage && matchesCategory && matchesFree;
      el.dataset.hidden = show ? 'false' : 'true';
      if (show) visible++;
    });

    const count = document.getElementById('filter-count');
    if (count) {
      count.textContent = `${visible} ${visible === 1 ? 'tool' : 'tools'}`;
    }

    // Show empty state when no tools match
    const emptyState = document.getElementById('empty-state');
    if (emptyState) {
      emptyState.style.display = visible === 0 ? 'block' : 'none';
    }
  }

  document.querySelectorAll<HTMLElement>('[data-filter-group]').forEach((group) => {
    const groupName = group.dataset.filterGroup as GroupName;
    group.querySelectorAll<HTMLButtonElement>('button[data-filter-value]').forEach((btn) => {
      btn.addEventListener('click', () => {
        // Single-select within group
        group.querySelectorAll<HTMLButtonElement>('button').forEach((b) => {
          b.setAttribute('aria-pressed', 'false');
        });
        btn.setAttribute('aria-pressed', 'true');
        state[groupName] = btn.dataset.filterValue ?? 'all';
        apply();
      });
    });
  });

  // Initial render
  apply();
</script>
