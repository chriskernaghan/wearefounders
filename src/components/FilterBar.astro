---
import { CATEGORIES } from '../data/taxonomy';

interface Props {
  hideCategoryFilter?: boolean;
  hideStageFilter?: boolean;
}

const { hideCategoryFilter = false } = Astro.props;
---
{!hideCategoryFilter && (
  <div class="category-strip" id="category-strip">
    <div class="category-strip__scroll-wrap">
      <div class="category-strip__pills" data-filter-group="category" id="category-pills">
        <button type="button" class="pill" data-filter-value="all" aria-pressed="true">All</button>
        {CATEGORIES.map((c) => (
          <button type="button" class="pill" data-filter-value={c.slug} aria-pressed="false">
            {c.label}
          </button>
        ))}
      </div>
      <div class="category-strip__fade" aria-hidden="true"></div>
      <button type="button" class="pill pill--accent category-strip__view-all" id="open-categories-modal" aria-haspopup="dialog">
        View all
      </button>
    </div>
  </div>
)}

<div class="filter-bar" id="filter-bar">
  <div class="container filter-bar__inner">
    <div class="filter-bar__left">
      <span class="filter-bar__count" id="filter-count">Loading…</span>
    </div>
    <div class="filter-bar__right">
      <label class="toggle" data-filter-group="freetier">
        <span class="toggle__label">Free tier only</span>
        <input type="checkbox" class="toggle__input" id="freetier-toggle" />
        <span class="toggle__track" aria-hidden="true">
          <span class="toggle__thumb"></span>
        </span>
      </label>
    </div>
  </div>
</div>

{!hideCategoryFilter && (
  <div class="modal" id="categories-modal" role="dialog" aria-modal="true" aria-labelledby="categories-modal-title" hidden>
    <div class="modal__backdrop" data-modal-close></div>
    <div class="modal__panel" role="document">
      <header class="modal__header">
        <h2 id="categories-modal-title">All categories</h2>
        <button type="button" class="modal__close" data-modal-close aria-label="Close">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M18 6L6 18M6 6l12 12" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
          </svg>
        </button>
      </header>
      <div class="modal__grid" id="modal-categories-grid">
        <button type="button" class="modal__category" data-modal-category="all">
          <strong>All</strong>
          <span>Show every tool in the directory.</span>
        </button>
        {CATEGORIES.map((c) => (
          <button type="button" class="modal__category" data-modal-category={c.slug}>
            <strong>{c.label}</strong>
            <span>{c.desc}</span>
          </button>
        ))}
      </div>
    </div>
  </div>
)}

<script>
  // Multi-axis client-side filter. With stage filter removed from the
  // home page, only category and freetier are managed here.
  type GroupName = 'stage' | 'category' | 'freetier';
  const state: Record<GroupName, string> = {
    stage: 'all',
    category: 'all',
    freetier: 'all',
  };

  function apply() {
    const tools = document.querySelectorAll<HTMLElement>('[data-tool]');
    let visible = 0;

    tools.forEach((el) => {
      const cats = (el.dataset.categories ?? '').split(',');
      const stages = (el.dataset.stages ?? '').split(',');
      const freeTier = el.dataset.freeTier ?? 'false';

      const matchesStage = state.stage === 'all' || stages.includes(state.stage);
      const matchesCategory = state.category === 'all' || cats.includes(state.category);
      const matchesFree = state.freetier === 'all' || freeTier === state.freetier;

      const show = matchesStage && matchesCategory && matchesFree;
      el.dataset.hidden = show ? 'false' : 'true';
      if (show) visible++;
    });

    const count = document.getElementById('filter-count');
    if (count) {
      count.textContent = `${visible} ${visible === 1 ? 'tool' : 'tools'}`;
    }

    const emptyState = document.getElementById('empty-state');
    if (emptyState) {
      emptyState.style.display = visible === 0 ? 'block' : 'none';
    }
  }

  function setCategoryActive(value: string) {
    document.querySelectorAll<HTMLButtonElement>(
      '[data-filter-group="category"] button[data-filter-value]'
    ).forEach((b) => {
      b.setAttribute('aria-pressed', b.dataset.filterValue === value ? 'true' : 'false');
    });
    state.category = value;
    apply();
  }

  // Category pills (single-select)
  document.querySelectorAll<HTMLElement>('[data-filter-group="category"]').forEach((group) => {
    group.querySelectorAll<HTMLButtonElement>('button[data-filter-value]').forEach((btn) => {
      btn.addEventListener('click', () => {
        setCategoryActive(btn.dataset.filterValue ?? 'all');
      });
    });
  });

  // Stage pills (still used on stage pages where the row may be hidden,
  // but the data-attribute hook persists for any other contexts)
  document.querySelectorAll<HTMLElement>('[data-filter-group="stage"]').forEach((group) => {
    group.querySelectorAll<HTMLButtonElement>('button[data-filter-value]').forEach((btn) => {
      btn.addEventListener('click', () => {
        group.querySelectorAll<HTMLButtonElement>('button').forEach((b) => {
          b.setAttribute('aria-pressed', 'false');
        });
        btn.setAttribute('aria-pressed', 'true');
        state.stage = btn.dataset.filterValue ?? 'all';
        apply();
      });
    });
  });

  // Free tier toggle (boolean)
  const freeTierToggle = document.getElementById('freetier-toggle') as HTMLInputElement | null;
  if (freeTierToggle) {
    freeTierToggle.addEventListener('change', () => {
      state.freetier = freeTierToggle.checked ? 'true' : 'all';
      apply();
    });
  }

  // Modal: open, close, select category
  const modal = document.getElementById('categories-modal');
  const openBtn = document.getElementById('open-categories-modal');
  if (modal && openBtn) {
    const open = () => {
      modal.hidden = false;
      document.body.style.overflow = 'hidden';
      modal.querySelectorAll<HTMLButtonElement>('[data-modal-category]').forEach((b) => {
        b.setAttribute('aria-pressed', b.dataset.modalCategory === state.category ? 'true' : 'false');
      });
    };
    const close = () => {
      modal.hidden = true;
      document.body.style.overflow = '';
    };

    openBtn.addEventListener('click', open);

    modal.querySelectorAll<HTMLElement>('[data-modal-close]').forEach((el) => {
      el.addEventListener('click', close);
    });

    modal.querySelectorAll<HTMLButtonElement>('[data-modal-category]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const value = btn.dataset.modalCategory ?? 'all';
        setCategoryActive(value);
        const inlinePill = document.querySelector<HTMLButtonElement>(
          `[data-filter-group="category"] button[data-filter-value="${value}"]`
        );
        inlinePill?.scrollIntoView({ behavior: 'smooth', inline: 'center', block: 'nearest' });
        close();
      });
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !modal.hidden) close();
    });
  }

  apply();
</script>
