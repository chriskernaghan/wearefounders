---
import { CATEGORY_MAP, STAGE_MAP } from '../data/taxonomy';

interface Props {
  tool: {
    id: string;
    data: {
      name: string;
      tagline: string;
      categories: string[];
      stages: string[];
      pricing_from: number | null;
      pricing_currency: string;
      free_tier: boolean;
      website?: string;
      logo?: string;
    };
  };
}

const { tool } = Astro.props;
const base = import.meta.env.BASE_URL;
const slug = tool.id.replace(/\.md$/, '');

const symbol = tool.data.pricing_currency === 'GBP' ? '£' : tool.data.pricing_currency === 'EUR' ? '€' : '$';

// Pricing display string. "From $X" pattern keeps copy future-proof.
let priceLabel: string;
if (tool.data.pricing_from === null) {
  priceLabel = 'Custom';
} else if (tool.data.pricing_from === 0) {
  priceLabel = 'Free';
} else {
  priceLabel = `From ${symbol}${tool.data.pricing_from}`;
}

// Logo resolution:
// 1. If tool.data.logo is explicitly set, use it (real brand asset)
// 2. Otherwise, derive favicon URL from the website using Google's S2 favicon service
// This gives every tool a logo automatically without per-tool work, and we can
// upgrade to real logos by setting tool.data.logo when ready.
let logoUrl: string | null = null;
if (tool.data.logo) {
  logoUrl = tool.data.logo;
} else if (tool.data.website) {
  try {
    const domain = new URL(tool.data.website).hostname;
    logoUrl = `https://www.google.com/s2/favicons?domain=${domain}&sz=64`;
  } catch {
    logoUrl = null;
  }
}

// Build data-attributes used by the client-side filter.
const categoriesAttr = tool.data.categories.join(',');
const stagesAttr = tool.data.stages.join(',');
---
<a
  class="tool-card"
  href={`${base}/${slug}/`}
  data-tool
  data-categories={categoriesAttr}
  data-stages={stagesAttr}
  data-free-tier={tool.data.free_tier ? 'true' : 'false'}
>
  <div class="tool-card__head">
    <div class="tool-card__head-left">
      {logoUrl && (
        <img class="tool-card__logo" src={logoUrl} alt={`${tool.data.name} logo`} loading="lazy" width="32" height="32" />
      )}
      <div class="tool-card__name">{tool.data.name}</div>
    </div>
    <div class="tool-card__price">
      {tool.data.free_tier && tool.data.pricing_from !== 0 && (
        <><strong>Free tier</strong><br /></>
      )}
      <strong>{priceLabel}</strong>
    </div>
  </div>
  <p class="tool-card__tagline">{tool.data.tagline}</p>
  <div class="tool-card__meta">
    {tool.data.categories.slice(0, 2).map((slug) => (
      <span class="pill">{CATEGORY_MAP[slug]?.label ?? slug}</span>
    ))}
    {tool.data.stages.map((slug) => (
      <span class="pill">{STAGE_MAP[slug]?.label ?? slug}</span>
    ))}
  </div>
</a>
