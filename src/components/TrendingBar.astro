---
// Trending leaderboard strip for the directory index.
// Place at the very top of src/layouts/BaseLayout.astro, above SiteHeader.
//
// Ranking data lives in src/data/trending.json, updated by hand once a week
// from GA4 (Reports > Engagement > Events, filtered to utm_campaign=
// founder_share, broken down by utm_content, sorted by count). See that
// file's _readme field for the exact steps.
//
// Tool names/links are resolved here from the live content collection, not
// stored in the JSON — this means a stale or mistyped slug in trending.json
// fails the build loudly instead of silently shipping a broken link or a
// name that's drifted from the actual listing.
import { getCollection } from 'astro:content';
import trendingData from '../data/trending.json';

const allTools = await getCollection('tools');

const trending = trendingData.slugs.map((slug) => {
  const tool = allTools.find((t) => t.id.replace(/\.md$/, '') === slug);
  if (!tool) {
    throw new Error(
      `TrendingBar: "${slug}" in src/data/trending.json does not match any listing in src/content/tools. ` +
      `Check for a typo, or remove it if the tool was unlisted.`
    );
  }
  return { name: tool.data.name, slug };
});

const base = import.meta.env.BASE_URL;
---
<div class="trending-bar">
  <div class="container trending-bar__inner">
    <span class="trending-bar__label">
      <span class="trending-bar__icon" aria-hidden="true">&#9650;</span>
      Trending this week
    </span>
    <ol class="trending-bar__list">
      {trending.map((tool, i) => (
        <li>
          <a href={`${base}${tool.slug}/`}>
            <span class="trending-bar__rank">{i + 1}</span>
            {tool.name}
          </a>
        </li>
      ))}
    </ol>
    <a class="trending-bar__cta" href={`${base}promote/`}>Get featured here &rarr;</a>
  </div>
</div>
