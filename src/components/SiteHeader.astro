---
const base = import.meta.env.BASE_URL;
---
<header class="site-header">
  <div class="container site-header__inner">
    <div class="site-header__brand-group">
      <a href="https://wearefounders.uk/" class="site-header__brand">
        We Are Founders
      </a>
      <span class="site-header__divider">·</span>
      <a href={base} class="site-header__tools">Tools</a>
    </div>
    <nav class="site-header__nav" aria-label="Primary">
      <a href={`${base}submit/`} class="site-header__submit">
        <span class="site-header__submit-desktop">Submit your Tool — $29</span>
        <span class="site-header__submit-mobile">Submit — $29</span>
      </a>
      <button
        type="button"
        class="theme-toggle"
        id="theme-toggle"
        aria-label="Toggle dark mode"
      >
        <!-- Moon icon (shown in light mode) -->
        <svg class="theme-toggle__icon theme-toggle__icon--moon" width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <!-- Sun icon (shown in dark mode) -->
        <svg class="theme-toggle__icon theme-toggle__icon--sun" width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="1.75"/>
          <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
        </svg>
      </button>
    </nav>
  </div>
</header>

<script>
  // Theme toggle — persists choice to localStorage. The initial theme
  // is set by the inline script in BaseLayout to prevent FOUC.
  const toggle = document.getElementById('theme-toggle');
  if (toggle) {
    toggle.addEventListener('click', () => {
      const current = document.documentElement.getAttribute('data-prefers-color-scheme');
      const next = current === 'dark' ? 'light' : 'dark';
      document.documentElement.setAttribute('data-prefers-color-scheme', next);
      localStorage.setItem('waf-theme', next);
    });
  }
</script>
